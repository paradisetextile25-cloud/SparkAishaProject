# ============================================
# SparkAisha Monorepo .gitignore
# ============================================

# ===================
# FRONTEND (Vite + React)
# ===================

# Dependencies
frontend/node_modules/
frontend/.pnp
frontend/.pnp.js
frontend/.yarn/

# Build outputs
frontend/dist/
frontend/dist-ssr/
frontend/build/
frontend/*.local

# Logs
frontend/logs/
frontend/*.log
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*
frontend/lerna-debug.log*

# Testing
frontend/coverage/
frontend/*.lcov
frontend/.nyc_output

# Environment variables
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/.env*.local

# Cache
frontend/.cache/
frontend/.vite-inspect/
frontend/.eslintcache
frontend/.stylelintcache

# ===================
# BACKEND (ASP.NET Core)
# ===================

# Build results
backend/**/bin/
backend/**/obj/
backend/**/out/

# Visual Studio files
backend/**/.vs/
backend/.vs/
backend/**/*.user
backend/**/*.userosscache
backend/**/*.sln.docstates
backend/**/*.suo
backend/**/*.user
backend/**/*.userprefs
backend/**/*.pidb
backend/**/*.sln.iml

# ReSharper
backend/**/_ReSharper*/
backend/**/*.[Rr]e[Ss]harper
backend/**/*.DotSettings.user

# NuGet
backend/**/packages/
backend/**/*.nupkg
backend/**/*.snupkg
backend/**/project.lock.json
backend/**/project.fragment.lock.json
backend/**/artifacts/

# ASP.NET Scaffolding
backend/**/ScaffoldingReadMe.txt

# Azure Functions
backend/**/local.settings.json

# User-specific files
backend/**/*.user
backend/**/*.rsuser
backend/**/*.suo
backend/**/*.sln.docstates

# ===================
# SHARED / GENERAL
# ===================

# OS files
.DS_Store
Thumbs.db
Desktop.ini
._*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*~
*.sw?

# Temporary files
*.tmp
*.temp
*.cache

# Backup files
*.backup
*.bak
*.old
*.orig
*BACKUP*/
*.BACKUP
.BACKUP*/

# Logs
*.log

# Environment files (sensitive data)
.env
.env.local
.env.*.local

# Old nested structure (cleanup)
frontend/spark-aisha-directory/

# Test files
test_payload.json
*.test.json

# Solution files that might be IDE-specific
*.sln.DotSettings
